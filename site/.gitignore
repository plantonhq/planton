# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/blob-report/
/.last-run.json

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated docs (copied from apis/ during build)
# Note: public/docs/index.md and other manual docs are committed
public/docs/catalog/

# generated sidebar structure (built by scripts/generate-docs-structure.ts)
public/docs-structure.json

# pagefind search index (generated at build time)
out/_pagefind/
public/_pagefind/
