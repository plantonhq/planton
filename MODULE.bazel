module(
    name = "openmcf",
)

# ─── Go rules + Gazelle ──────────────────────────────────────────────────────
bazel_dep(name = "rules_go", version = "0.59.0")
bazel_dep(name = "gazelle", version = "0.47.0")

# Pin the Go toolchain Bazel uses (hermetic; no host Go required)
go_sdk = use_extension("@rules_go//go:extensions.bzl", "go_sdk")
go_sdk.download(version = "1.25.0")
go_sdk.nogo(nogo = "//:openmcf_nogo")

# Read Go deps from this repo's go.mod (bzlmod-friendly)
go_deps = use_extension("@gazelle//:extensions.bzl", "go_deps")
go_deps.from_file(go_mod = "//:go.mod")
go_deps.module(
    path = "buf.build/go/protovalidate",
    sum = "h1:pQqEQRpOo4SqS60qkvmhLTTQU9JwzEvdyiqAtXa5SeY=",
    version = "v1.1.0",
)
go_deps.module(
    path = "golang.org/x/tools",
    sum = "h1:yLkxfA+Qnul4cs9QA3KnlFu0lVmd8JJfoq+E41uSutA=",
    version = "v0.40.0",
)
use_repo(
    go_deps,
    "build_buf_gen_go_bufbuild_protovalidate_protocolbuffers_go",
    "build_buf_go_protovalidate",
    "com_github_aws_aws_sdk_go_v2",
