.idea
.DS_Store
generated/
# Rendered InfraChart output from `planton chart build` (chart-root artifact)
charts/*/*/template.yaml
build/
bin/
site/node_modules/
site/build/
site/.yarn/*
site/!next-env.d.ts
apis/internal/
apis/generated/

# Swap the comments on the following lines if you don't wish to use zero-installs
# Documentation here: https://yarnpkg.com/features/zero-installs
site/!.yarn/cache
#.pnp.*

# Terraform init/plan/apply artifacts (generated locally, never committed)
**/.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
terraform.tfplan
*.tfplan
# Bazel output symlinks. Bazel names the convenience symlink after the workspace
# directory (bazel-<dirname>), so a per-clone-name list can never be complete --
# the glob covers every clone name. The tracked wrapper `bazelw` has no hyphen and
# is not matched.
bazel-*
Pulumi.*.yaml
!Pulumi.yaml
test-*.log
.cursor/workspace/
cursor/
.git-ignored/
**/iac/pulumi/pulumi
_cursor/
_a-gitignored-workspace
# Backend generated files
backend/apis/gen/
backend/bin/
backend/server

# Web-app generated files
web-app/src/gen/

*.sh
!app/entrypoint-unified.sh
!tools/ci/release/package_content.sh
# CI guard scripts must be tracked (run by .github/workflows/lint.*.yaml)
!hack/guards/*.sh
**/*.env
# Local-only provider credentials for live E2E (see forge rule "Post-Forge Live
# E2E Validation"). NEVER commit. Note **/*.env above does not match *.env.e2e.
**/.env.e2e
**/*.env.e2e
_aacursor/
backend.tf
/pulumi

# E2E test artifacts (generated during pulumi runs)
**/iac/pulumi/stack-input.yaml
